{
  "name": "knowledgegrapher",
  "version": "1.0.0",
  "description": "NLP Text-to-Entity Knowledge Graph Visualizer",
  "scripts": {
    "install-all": "npm.cmd install && npm.cmd install --prefix server && npm.cmd install --prefix client",
    "server": "npm.cmd run dev --prefix server",
    "client": "npm.cmd run dev --prefix client",
    "dev": "concurrently \"npm.cmd run server\" \"npm.cmd run client\""
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
